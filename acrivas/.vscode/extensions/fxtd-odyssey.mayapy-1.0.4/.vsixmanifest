      <Property Id="Microsoft.VisualStudio.Code.Engine" Value="^1.32.0" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionDependencies" Value="ms-python.python,saviof.mayacode" />
      <Property Id="Microsoft.VisualStudio.Code.ExtensionPack" Value="" />
      <Property Id="Microsoft.VisualStudio.Code.LocalizedLanguages" Value="" />
      
        <Property Id="Microsoft.VisualStudio.Services.Links.Source" Value="https://github.com/FXTD-ODYSSEY/vscode-mayapy" />
        <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/FXTD-ODYSSEY/vscode-mayapy" />
        
          <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/FXTD-ODYSSEY/vscode-mayapy" />
        
      
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/FXTD-ODYSSEY/vscode-mayapy/issues" />
      
